{
  "name": "@f3rnox/node-ts-lib-template",
  "type": "module",
  "version": "0.0.8",
  "private": true,
  "description": "A template repository for Node.JS TypeScript libraries",
  "keywords": [
    "typescript",
    "template",
    "boilerplate",
    "markdownlint",
    "prettier",
    "commitlint",
    "library",
    "vitest",
    "eslint",
    "typedoc"
  ],
  "homepage": "https://github.com/f3rnox/node-ts-lib-template",
  "bugs": {
    "url": "https://github.com/f3rnox/node-ts-lib-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/f3rnox/node-ts-lib-template"
  },
  "license": "MIT",
  "author": "Cris Mihalache <f3rnox42@gmail.com>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm build:ts && pnpm build:docs",
    "build:docs": "typedoc --out ./docs ./src && cp LICENSE.md docs/LICENSE.md && cp CHANGELOG.md docs/CHANGELOG.md",
    "build:ts": "NODE_PATH=./src tsc -p tsconfig.json",
    "format": "pnpm format:prettier",
    "format:check": "pnpm format:prettier:check",
    "format:prettier": "prettier --write .",
    "format:prettier:check": "prettier --check .",
    "lint": "pnpm lint:markdownlint && pnpm lint:eslint",
    "lint:eslint": "eslint package.json src/**/*",
    "lint:eslint:fix": "eslint package.json src/**/*",
    "lint:fix": "pnpm lint:markdownlint:fix && pnpm lint:eslint:fix",
    "lint:markdownlint": "markdownlint README.md",
    "lint:markdownlint:fix": "markdownlint --fix README.md",
    "prepare": "husky",
    "prepare-release": "pnpm build && git add docs",
    "prepublish": "pnpm build",
    "release": "pnpm prepare-release && pnpm update-version && git push --follow-tags origin main",
    "serve:coverage": "http-server ./coverage",
    "serve:docs": "http-server ./docs",
    "test": "NODE_PATH=./src NODE_ENV=test vitest",
    "update-deps": "updates -u -g -c",
    "update-version": "standard-version -a"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/format": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-plugin-package-json": "^0.91.1",
    "globals": "^17.4.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.48.0",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "remark": "^15.0.1",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "updates": "^17.13.5",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
